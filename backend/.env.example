GEMINI_API_KEY=your_gemini_api_key
MONGODB_URI=mongodb://localhost:27017

# Amadeus (live flights + hotels)
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# RapidAPI (live trains + buses - set provider specific endpoints/hosts)
RAPIDAPI_KEY=your_rapidapi_key
TRAIN_API_URL=https://example-train-api-endpoint
TRAIN_API_HOST=example-train-api-host
TRAIN_ITEMS_PATH=data
BUS_API_URL=https://example-bus-api-endpoint
BUS_API_HOST=example-bus-api-host
BUS_ITEMS_PATH=data
